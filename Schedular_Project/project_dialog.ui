}

QLabel#dialog_title_label {
    color: #2E4A6B;
    font-size: 16px;
    font-weight: 500;
    padding: 8px 0;
}

QLabel#row_name_label {
    color: #2C2F33;
    font-size: 13px;
    font-weight: 500;
}

QLabel#row_count_label {
    color: #8A8F95;
    font-size: 11px;
}
</string>
