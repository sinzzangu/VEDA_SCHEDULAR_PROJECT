   <string notr="true">QDialog {
    background-color: #FAFBFC;
}

QLineEdit {
    background-color: white;
    border: 1px solid #D5D8DC;
    border-radius: 4px;
    padding: 6px 8px;
    font-size: 12px;
    color: #2C2F33;
    min-height: 20px;
}

QLineEdit:focus {
    border-color: #2E4A6B;
}

QPushButton {
    border-radius: 6px;
    padding: 8px 16px;
    font-size: 12px;
    font-weight: 500;
    min-height: 20px;
}

QPushButton#add_button {
    background-color: #2E4A6B;
    color: white;
    border: none;
    min-width: 60px;
}

QPushButton#add_button:hover {
    background-color: #3A5A7D;
}

QPushButton#close_button {
    background-color: white;
    color: #5F6469;
    border: 1px solid #D5D8DC;
    min-width: 70px;
}

QPushButton#close_button:hover {
    background-color: #F5F7FA;
}

QPushButton#row_delete_button {
    background-color: white;
    color: #E24B4A;
    border: 1px solid #E24B4A;
    border-radius: 4px;
    padding: 4px 10px;
    font-size: 11px;
    min-width: 40px;
    min-height: 16px;
}

QPushButton#row_delete_button:hover {
    background-color: #FFF5F5;
}

QListWidget {
    background-color: white;
    border: 1px solid #E5E8EB;
    border-radius: 4px;
    padding: 4px;
    outline: none;
}

QListWidget::item {
    border-bottom: 1px solid #F0F2F5;
    padding: 0px;
}

QListWidget::item:last-child {
    border-bottom: none;
}

QListWidget::item:selected {
    background-color: transparent;
    color: #2C2F33;
}

QLabel {
    color: #2C2F33;
    font-size: 12px;
}

QLabel#field_label {
    color: #8A8F95;
    font-size: 11px;
    font-weight: 500;
}

QLabel#section_label {
    color: #8A8F95;
    font-size: 11px;
    font-weight: 500;
