  <property name="styleSheet">
   <string notr="true">/* ===== 사이드바 ===== */
QWidget#sidebar_widget {
    background-color: #2E4A6B;
}

QLabel#logo_icon_label {
    color: white;
    font-size: 14px;
}

QLabel#logo_text_label {
    color: white;
    font-size: 14px;
    font-weight: 500;
}

QWidget#user_card_widget {
    background-color: rgba(255, 255, 255, 20);
    border-radius: 8px;
}

QLabel#user_avatar_label {
    background-color: rgba(255, 255, 255, 50);
    color: white;
    border-radius: 16px;
    min-width: 32px;
    max-width: 32px;
    min-height: 32px;
    max-height: 32px;
    qproperty-alignment: AlignCenter;
    font-size: 12px;
}

QLabel#user_name_label {
    color: white;
    font-size: 12px;
    font-weight: 500;
}

QLabel#user_status_label {
    color: rgba(255, 255, 255, 150);
    font-size: 10px;
}

QLabel#menu_title_label,
QLabel#category_title_label {
    color: rgba(255, 255, 255, 120);
    font-size: 10px;
    padding: 4px 12px;
}

QListWidget#menu_list {
    background-color: transparent;
    border: none;
    color: white;
    font-size: 13px;
    outline: none;
}

QListWidget#menu_list::item {
    padding: 10px 12px;
    border-radius: 6px;
    margin: 2px 4px;
}

QListWidget#menu_list::item:selected {
    background-color: rgba(255, 255, 255, 30);
    color: white;
}

QListWidget#menu_list::item:hover {
    background-color: rgba(255, 255, 255, 15);
}

QCheckBox {
    color: rgba(255, 255, 255, 220);
    font-size: 12px;
    padding: 4px 12px;
    spacing: 8px;
}

QPushButton#logout_button {
    background-color: transparent;
    color: rgba(255, 255, 255, 150);
    border: none;
    text-align: left;
    padding: 10px 16px;
    font-size: 12px;
}

QPushButton#logout_button:hover {
    color: white;
    background-color: rgba(255, 255, 255, 15);
    border-radius: 6px;
}

/* ===== 메인 영역 ===== */
QWidget#main_area_widget {
    background-color: #FAFBFC;
}

QWidget#top_toolbar_widget {
    background-color: white;
    border-bottom: 1px solid #E5E8EB;
}

QLabel#page_title_label {
    color: #2E4A6B;
    font-size: 18px;
    font-weight: 500;
}

QLabel#page_subtitle_label {
    color: #8A8F95;
    font-size: 12px;
}

QComboBox#project_combobox {
    background-color: white;
    border: 1px solid #D5D8DC;
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 12px;
    min-width: 100px;
    min-height: 24px;
    color: #2C2F33;
}

QComboBox#project_combobox:hover {
    border-color: #2E4A6B;
}

QPushButton#add_schedule_button {
    background-color: #2E4A6B;
    color: white;
    border-radius: 6px;
    padding: 8px 14px;
    font-size: 12px;
    font-weight: 500;
    border: none;
    min-height: 24px;
}

QPushButton#add_schedule_button:hover {
    background-color: #3A5A7D;
}

QScrollArea#timeline_scroll {
    border: none;
    background-color: transparent;
}

QWidget#timeline_content_widget {
    background-color: #FAFBFC;
}</string>
