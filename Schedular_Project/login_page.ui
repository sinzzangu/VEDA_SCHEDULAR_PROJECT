   <string notr="true">
/* 전체 배경 */
QWidget#Widget {
    background-color: #F5F7FA;
}

/* 왼쪽 다크 패널 */
QFrame#frame_left {
    background-color: #2E4A6B;
    border-radius: 12px;
}

/* 모든 기본 텍스트는 다크 */
QLabel {
    color: #2C2F33;
    background: transparent;
}

/* 왼쪽 패널 안의 텍스트는 화이트 */
QFrame#frame_left QLabel {
    color: #FFFFFF;
}

/* 타이틀 */
QLabel#label_scheduler_title {
    color: #FFFFFF;
    font-size: 16px;
    font-weight: 600;
}

QLabel#label_scheduler_summery {
    color: #FFFFFF;
    font-size: 18px;
    font-weight: 700;
    padding: 8px;
}

QLabel#label_scheduler_addsummery {
    color: #D5D8DC;
    font-size: 11px;
}

/* 로그인 제목 */
QLabel#label_login {
    color: #1F2937;
    font-size: 24px;
    font-weight: 700;
}

QLabel#label_login_summery {
    color: #6B7280;
    font-size: 12px;
}

/* 입력 필드 레이블 */
QLabel#label_id, QLabel#label_pw {
    color: #374151;
    font-size: 12px;
    font-weight: 500;
    padding-top: 4px;
}

/* 입력 필드 */
QLineEdit {
    background-color: #FFFFFF;
    color: #1F2937;
    border: 1px solid #D5D8DC;
    border-radius: 6px;
    padding: 8px 10px;
    font-size: 12px;
    min-height: 18px;
}

QLineEdit:focus {
    border: 1px solid #2E4A6B;
    background-color: #FFFFFF;
}

/* 버튼 공통 */
QPushButton {
    background-color: #2E4A6B;
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    padding: 9px 16px;
    font-size: 13px;
    font-weight: 500;
    min-height: 22px;
}

QPushButton:hover {
    background-color: #3D5F87;
}

QPushButton:pressed {
    background-color: #243A55;
}

/* 회원가입 버튼은 아웃라인 스타일 */
QPushButton#pushButton_register {
    background-color: #FFFFFF;
    color: #2E4A6B;
    border: 1px solid #2E4A6B;
}

QPushButton#pushButton_register:hover {
    background-color: #F5F7FA;
    color: #3D5F87;
    border-color: #3D5F87;
}

/* 하단 copyright */
QLabel#label_project_bottom {
    color: #9CA3AF;
    font-size: 10px;
    padding-top: 8px;
}
